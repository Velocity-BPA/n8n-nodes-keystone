{
  "name": "n8n-nodes-keystone",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Keystone hardware wallet integration providing 25 resources and 200+ operations for air-gapped cryptocurrency signing, multi-chain support, QR code workflows, and wallet integrations.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-keystone.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-keystone#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-keystone/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "keystone",
    "hardware-wallet",
    "cryptocurrency",
    "bitcoin",
    "ethereum",
    "solana",
    "cosmos",
    "air-gapped",
    "qr-code",
    "psbt",
    "multi-sig",
    "cold-storage",
    "blockchain",
    "signing",
    "ur-codec",
    "uniform-resource",
    "metamask",
    "watch-only"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/KeystoneDevice.credentials.js",
      "dist/credentials/KeystoneSdk.credentials.js",
      "dist/credentials/KeystoneNetwork.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Keystone/Keystone.node.js",
      "dist/nodes/Keystone/KeystoneTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@keystonehq/animated-qr": "^0.8.0",
    "@keystonehq/bc-ur-registry": "^0.7.0",
    "@keystonehq/bc-ur-registry-btc": "^0.6.0",
    "@keystonehq/bc-ur-registry-eth": "^0.19.0",
    "@keystonehq/bc-ur-registry-sol": "^0.4.0",
    "@keystonehq/keystone-sdk": "^0.5.0",
    "@keystonehq/ur-decoder": "^0.12.0",
    "@solana/web3.js": "^1.95.0",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^6.1.6",
    "bs58": "^6.0.0",
    "bs58check": "^4.0.0",
    "cbor": "^9.0.2",
    "ethers": "^6.13.0",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/jsqr": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^5.0.0",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.52.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
